						"index": 0
					}
				]
			]
		},
		"Extract Tool Call": {
			"main": [
				[
					{
						"node": "Call MCP Tool",
						"type": "main",
						"index": 0
					}
				]
			]
		},
		"Call MCP Tool": {
			"main": [
				[
					{
						"node": "Check Success",
						"type": "main",
						"index": 0
					}
				]
			]
		},
		"Check Success": {
			"main": [
				[
					{
						"node": "Success Response",
						"type": "main",
