					}
				],
				[
					{
						"node": "Error Response",
						"type": "main",
						"index": 0
					}
				]
			]
		},
		"Success Response": {
			"main": [
				[
					{
						"node": "Prepare Notification",
						"type": "main",
						"index": 0
					}
				]
			]
		}
	},
